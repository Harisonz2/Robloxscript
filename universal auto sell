local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local isSellingHand = false
local isSellingAll = false
local isScriptActive = true -- ควบคุม Loop การทำงานเบื้องหลัง

-- ==============================
-- 1. สร้าง UI
-- ==============================
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "UniversalAutoSellUI"
screenGui.Parent = pcall(function() return CoreGui.Name end) and CoreGui or player:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 240, 0, 140) -- ขนาดสำหรับ 2 ปุ่ม
mainFrame.Position = UDim2.new(0.5, -120, 0.8, 0)
mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
mainFrame.BorderSizePixel = 0
mainFrame.ClipsDescendants = true
mainFrame.Active = true
mainFrame.Draggable = true 
mainFrame.Parent = screenGui

local uiCorner = Instance.new("UICorner")
uiCorner.CornerRadius = UDim.new(0, 8)
uiCorner.Parent = mainFrame

local uiScale = Instance.new("UIScale")
uiScale.Scale = 1
uiScale.Parent = mainFrame

local topBar = Instance.new("Frame")
topBar.Size = UDim2.new(1, 0, 0, 30)
topBar.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
topBar.BorderSizePixel = 0
topBar.Parent = mainFrame

local title = Instance.new("TextLabel")
title.Size = UDim2.new(0, 130, 1, 0)
title.Position = UDim2.new(0, 10, 0, 0)
title.BackgroundTransparency = 1
title.Text = "Universal Auto Sell"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.Font = Enum.Font.GothamBold
title.TextSize = 12
title.TextXAlignment = Enum.TextXAlignment.Left
title.Parent = topBar

-- เครดิต
local credits = Instance.new("TextLabel")
credits.Size = UDim2.new(0, 60, 1, 0)
credits.Position = UDim2.new(0, 125, 0, 0)
credits.BackgroundTransparency = 1
credits.Text = "By Phumipad"
credits.TextColor3 = Color3.fromRGB(150, 150, 150)
credits.Font = Enum.Font.Gotham
credits.TextSize = 9
credits.TextXAlignment = Enum.TextXAlignment.Left
credits.Parent = topBar

local foldButton = Instance.new("TextButton")
foldButton.Size = UDim2.new(0, 25, 0, 30)
foldButton.Position = UDim2.new(1, -50, 0, 0)
foldButton.BackgroundTransparency = 1
foldButton.Text = "-"
foldButton.TextColor3 = Color3.fromRGB(255, 255, 255)
foldButton.Font = Enum.Font.GothamBold
foldButton.TextSize = 18
foldButton.Parent = topBar

local closeButton = Instance.new("TextButton")
closeButton.Size = UDim2.new(0, 25, 0, 30)
closeButton.Position = UDim2.new(1, -25, 0, 0)
closeButton.BackgroundTransparency = 1
closeButton.Text = "X"
closeButton.TextColor3 = Color3.fromRGB(255, 80, 80)
closeButton.Font = Enum.Font.GothamBold
closeButton.TextSize = 14
closeButton.Parent = topBar

-- ปุ่ม Auto Sell Hand
local sellHandBtn = Instance.new("TextButton")
sellHandBtn.Size = UDim2.new(1, -20, 0, 40)
sellHandBtn.Position = UDim2.new(0, 10, 0, 40) 
sellHandBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
sellHandBtn.Text = "Auto Sell Hand: OFF"
sellHandBtn.TextColor3 = Color3.fromRGB(255, 50, 50)
sellHandBtn.Font = Enum.Font.GothamBold
sellHandBtn.TextSize = 14
sellHandBtn.Parent = mainFrame
Instance.new("UICorner", sellHandBtn).CornerRadius = UDim.new(0, 6)

-- ปุ่ม Auto Sell All
local sellAllBtn = Instance.new("TextButton")
sellAllBtn.Size = UDim2.new(1, -20, 0, 40)
sellAllBtn.Position = UDim2.new(0, 10, 0, 90) 
sellAllBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
sellAllBtn.Text = "Auto Sell All: OFF"
sellAllBtn.TextColor3 = Color3.fromRGB(255, 50, 50)
sellAllBtn.Font = Enum.Font.GothamBold
sellAllBtn.TextSize = 14
sellAllBtn.Parent = mainFrame
Instance.new("UICorner", sellAllBtn).CornerRadius = UDim.new(0, 6)

-- ==============================
-- 2. การโต้ตอบกับ UI (พับ, ปิด, ซูม, กดปุ่ม)
-- ==============================
local isFolded = false
foldButton.MouseButton1Click:Connect(function()
    isFolded = not isFolded
    if isFolded then
        mainFrame:TweenSize(UDim2.new(0, 240, 0, 30), "Out", "Quad", 0.2, true)
        foldButton.Text = "+"
    else
        mainFrame:TweenSize(UDim2.new(0, 240, 0, 140), "Out", "Quad", 0.2, true)
        foldButton.Text = "-"
    end
end)

closeButton.MouseButton1Click:Connect(function()
    isScriptActive = false
    isSellingHand = false
    isSellingAll = false
    screenGui:Destroy() 
end)

sellHandBtn.MouseButton1Click:Connect(function()
    isSellingHand = not isSellingHand
    if isSellingHand then
        sellHandBtn.Text = "Auto Sell Hand: ON"
        sellHandBtn.TextColor3 = Color3.fromRGB(255, 180, 50) 
    else
        sellHandBtn.Text = "Auto Sell Hand: OFF"
        sellHandBtn.TextColor3 = Color3.fromRGB(255, 50, 50)
    end
end)

sellAllBtn.MouseButton1Click:Connect(function()
    isSellingAll = not isSellingAll
    if isSellingAll then
        sellAllBtn.Text = "Auto Sell All: ON"
        sellAllBtn.TextColor3 = Color3.fromRGB(255, 180, 50) 
    else
        sellAllBtn.Text = "Auto Sell All: OFF"
        sellAllBtn.TextColor3 = Color3.fromRGB(255, 50, 50)
    end
end)

-- ระบบซูมด้วยลูกกลิ้งเมาส์
mainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseWheel then
        local newScale = uiScale.Scale + (input.Position.Z * 0.1)
        uiScale.Scale = math.clamp(newScale, 0.5, 2.0)
    end
end)

-- ==============================
-- 3. Loop ขายของอัตโนมัติ (ทุกๆ 2 วินาที)
-- ==============================
task.spawn(function()
    while isScriptActive do
        task.wait(2) 
        
        if isSellingAll then
            pcall(function()
                ReplicatedStorage:WaitForChild("SellRequest"):FireServer("all")
            end)
        elseif isSellingHand then
            -- จะทำงานเมื่อ Sell All ปิดอยู่เท่านั้น เพื่อไม่ให้ยิง Remote ซ้ำซ้อน
            pcall(function()
                ReplicatedStorage:WaitForChild("SellRequest"):FireServer("hand")
            end)
        end
        
    end
end)
